# Copia este archivo como .env.local y rellena los valores de tu proyecto Appwrite.
# En Netlify, agrega estas MISMAS variables en: Site settings -> Environment variables.

# --- Públicas (se exponen al navegador) ---
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT=
NEXT_PUBLIC_APPWRITE_DATABASE=
NEXT_PUBLIC_APPWRITE_USERS_COLLECTION=
NEXT_PUBLIC_APPWRITE_FILES_COLLECTION=
NEXT_PUBLIC_APPWRITE_BUCKET=

# --- Secreta (SOLO servidor, nunca se expone) ---
NEXT_APPWRITE_KEY=
